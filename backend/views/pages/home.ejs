<% 
let displayName = "Bel(le) inconnu(e)";

    if(typeof user.name !== 'undefined' && user.name){
        if(user.sex === "F"){
            displayName= "Mme " + user.name;
            
        } else if(user.sex === "M") {
            displayName = "Mr " + user.name;
        } else {
            displayName = user.name;
        }
    } else if(user.sex === "F"){
        displayName = "belle inconnue";
    } else if(user.sex === "M"){
        displayName = "bel inconnu";
    } 
%>

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/css/main.css">
</head>
<body>
    <h1>Coucou test

        <%= displayName %>
    </h1>

</body>
</html>